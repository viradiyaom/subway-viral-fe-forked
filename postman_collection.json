        {
          "name": "Step 2+3 — Punch In (Biometric + Token + Device)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('attendance_id', pm.response.json().data.attendance._id);",
