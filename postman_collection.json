              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-device-id",
                "value": "staff-device-001",
                "description": "Must match Users.device_id"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shop_id\": \"{{shop_id}}\",\n  \"location_token\": \"{{location_token}}\",\n  \"biometric_verified\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/attendance/punch-in",
              "host": ["{{base_url}}"],
              "path": ["api", "attendance", "punch-in"]
            }
          }
        },
