              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"item_id\": \"{{item_id}}\",\n  \"issue_note\": \"Screen cracked on impact — unusable\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/inventory/queries",
              "host": ["{{base_url}}"],
              "path": ["api", "inventory", "queries"]
            }
          }
        },
        {
          "name": "Get Query by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/inventory/queries/{{query_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "inventory", "queries", "{{query_id}}"]
            }
          }
        },
        {
          "name": "Close Query (auto-reverts item → Good)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  console.log('✅ Item should now be Good');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"repair_cost\": 150,\n  \"resolve_note\": \"Replaced screen panel — fully functional\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/inventory/queries/{{query_id}}/close",
              "host": ["{{base_url}}"],
              "path": ["api", "inventory", "queries", "{{query_id}}", "close"]
            }
          }
        }
      ]
    },
    {
      "name": "🔍 Health Check",
      "item": [
        {
          "name": "Health",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Swagger JSON",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api-docs.json",
              "host": ["{{base_url}}"],
              "path": ["api-docs.json"]
            }
          }
        }
      ]
    }
  ]
